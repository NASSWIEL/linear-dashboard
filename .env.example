# Linear Personal API key — Linear → Settings → API → Personal API keys.
# Used server-side only (route handlers). Never exposed to the browser.
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxx

# Linear team key to pull issues for (Recast-test = REC).
LINEAR_TEAM_KEY=REC

# Same team key, exposed to the client only for display in the sidebar header.
NEXT_PUBLIC_LINEAR_TEAM_KEY=REC
